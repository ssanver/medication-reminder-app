{
  "expo": {
    "name": "Pill Mind",
    "slug": "medication-reminder",
    "scheme": "medication-reminder",
    "icon": "./assets/icon.png",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#1256DB"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2",
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.suleymansanver.medicationreminder",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "suleymansanver-001-site1.stempurl.com": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            }
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1256DB"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil fotoğrafı seçmek için galeri erişimi gerekir.",
          "cameraPermission": "Profil fotoğrafı çekmek için kamera erişimi gerekir."
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
