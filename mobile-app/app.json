{
  "expo": {
    "name": "Pill Mind",
    "slug": "medication-reminder",
    "scheme": "medication-reminder",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#1256DB"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2",
      "bundleIdentifier": "com.suleymansanver.medicationreminder"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1256DB"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil fotoğrafı seçmek için galeri erişimi gerekir.",
          "cameraPermission": "Profil fotoğrafı çekmek için kamera erişimi gerekir."
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
